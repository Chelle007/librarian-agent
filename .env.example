# --- Required for live Gemini (handle, benchmark, gemini embedder/eval) ---
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Optional ---
# Where your Obsidian vault lives (default: sibling ../vault)
# LIBRARIAN_VAULT=/absolute/path/to/vault

# Force embedder: "gemini" | "hashing" (default: gemini if a key is set, else hashing)
# LIBRARIAN_EMBEDDER=gemini
